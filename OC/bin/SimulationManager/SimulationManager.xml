<?xml version="1.0" encoding="utf-8"?>
<NOM:Nex1ObjectModel xmlns:NOM="lignex1.sw.nframework.NOM" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="lignex1.sw.nframework.NOM NOM.xsd" version="0.1" name="SimulationManager" date="2026-06-18" author="SAMS OC">
  <NOM:interactions>
    <!-- OC Publish -->
    <NOM:interaction name="StartSimulation" id="0x06" sharing="Publish" orderType="Receive" alignment="false" semantics="모의 시작/중지 명령 (OC 송신)">
      <NOM:parameter name="Header" dataType="MessageHeaderStruct" />
      <NOM:parameter name="simulationStatus" dataType="boolean" />
    </NOM:interaction>
    <NOM:interaction name="Stop" id="0x10" sharing="Publish" orderType="Receive" alignment="false" semantics="모의 중지 명령 (OC 송신)">
      <NOM:parameter name="Header" dataType="MessageHeaderStruct" />
      <NOM:parameter name="stopFlag" dataType="boolean" />
    </NOM:interaction>
    <!-- OC Subscribe: 각 CSC 1Hz 상태 수신 -->
    <NOM:interaction name="ATSStatus" id="0x02" sharing="Subscribe" orderType="Receive" alignment="false" semantics="ATS 상태/위치 주기 수신 (1Hz)">
      <NOM:parameter name="Header" dataType="MessageHeaderStruct" />
      <NOM:parameter name="status" dataType="intBE" />
      <NOM:parameter name="targetCount" dataType="uintBE" />
      <NOM:parameter name="targetInfo" dataType="ATSInformationStruct" size="20" />
    </NOM:interaction>
    <NOM:interaction name="RSSStatus" id="0x03" sharing="Subscribe" orderType="Receive" alignment="false" semantics="RSS 상태 주기 수신 (1Hz)">
      <NOM:parameter name="Header" dataType="MessageHeaderStruct" />
      <NOM:parameter name="status" dataType="intBE" />
    </NOM:interaction>
    <NOM:interaction name="MSSStatus" id="0x04" sharing="Subscribe" orderType="Receive" alignment="false" semantics="MSS 유도탄 상태 주기 수신 (1Hz)">
      <NOM:parameter name="Header" dataType="MessageHeaderStruct" />
      <NOM:parameter name="status" dataType="intBE" />
      <NOM:parameter name="missileCount" dataType="uintBE" />
      <NOM:parameter name="missileInfo" dataType="MSSInformationStruct" size="4" />
    </NOM:interaction>
    <NOM:interaction name="MLSStatus" id="0x05" sharing="Subscribe" orderType="Receive" alignment="false" semantics="MLS 발사대 상태 주기 수신 (1Hz)">
      <NOM:parameter name="Header" dataType="MessageHeaderStruct" />
      <NOM:parameter name="status" dataType="intBE" />
      <NOM:parameter name="launcherInfo" dataType="MLSInformationStruct" />
    </NOM:interaction>
  </NOM:interactions>
  <NOM:dataTypes>
    <NOM:basicTypes />
    <NOM:enumerationTypes />
    <NOM:complexTypes />
  </NOM:dataTypes>
  <NOM:notes />
</NOM:Nex1ObjectModel>

