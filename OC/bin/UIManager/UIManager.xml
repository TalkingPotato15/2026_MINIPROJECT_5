<?xml version="1.0" encoding="UTF-8"?>
<NOM:Nex1ObjectModel xmlns:NOM="lignex1.sw.nframework.NOM"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="lignex1.sw.nframework.NOM NOM.xsd"
	version="0.1" name="UIManager" date="2026-06-18" author="SAMS OC">

	<NOM:interactions>

		<!-- ============================================================ -->
		<!-- OC Publish : GUI → 내부 Manager로 전달하는 명령 메시지         -->
		<!-- ============================================================ -->

		<!-- 0x01 Scenario : OC → ATS/RSS/MLS/MSS -->
		<NOM:interaction name="Scenario" id="0x01" sharing="Publish"
			orderType="Receive" alignment="false" semantics="SAMS scenario distribution">
			<NOM:parameter name="Header" dataType="MessageHeaderStruct"/>
			<NOM:parameter name="sceneInfo" dataType="TargetScenarioStruct" size="4"/>
			<NOM:parameter name="rssPos" dataType="PosStruct"/>
			<NOM:parameter name="rssRadius" dataType="uintBE"/>
			<NOM:parameter name="mlsPos" dataType="PosStruct"/>
		</NOM:interaction>

		<!-- 0x06 StartSimulation : OC → ATS/RSS/MLS/MSS -->
		<NOM:interaction name="StartSimulation" id="0x06" sharing="Publish"
			orderType="Receive" alignment="false" semantics="SAMS start simulation command">
			<NOM:parameter name="Header" dataType="MessageHeaderStruct"/>
			<NOM:parameter name="startFlag" dataType="uintBE"/>
		</NOM:interaction>

		<!-- 0x07 ATSInformationToRSS : OC → RSS (ATS 위치 릴레이) -->
		<NOM:interaction name="ATSInformationToRSS" id="0x07" sharing="Publish"
			orderType="Receive" alignment="false" semantics="SAMS ATS information relay to RSS">
			<NOM:parameter name="Header" dataType="MessageHeaderStruct"/>
			<NOM:parameter name="targetInfo" dataType="ATSInformationStruct" size="4"/>
		</NOM:interaction>

		<!-- 0x09 LaunchCommand : OC → MLS -->
		<NOM:interaction name="LaunchCommand" id="0x09" sharing="Publish"
			orderType="Receive" alignment="false" semantics="SAMS launch command">
			<NOM:parameter name="Header" dataType="MessageHeaderStruct"/>
			<NOM:parameter name="targetID" dataType="uintBE"/>
		</NOM:interaction>

		<!-- 0x0c MSSInformationDownlinkToRSS : OC → RSS (MSS 유도탄 위치 릴레이) -->
		<NOM:interaction name="MSSInformationDownlinkToRSS" id="0x0c" sharing="Publish"
			orderType="Receive" alignment="false" semantics="SAMS MSS information downlink to RSS">
			<NOM:parameter name="Header" dataType="MessageHeaderStruct"/>
			<NOM:parameter name="missileInfo" dataType="MSSInformationStruct" size="4"/>
		</NOM:interaction>

		<!-- 0x0e ATSInterceptionResult : OC → ATS -->
		<NOM:interaction name="ATSInterceptionResult" id="0x0e" sharing="Publish"
			orderType="Receive" alignment="false" semantics="SAMS ATS interception result">
			<NOM:parameter name="Header" dataType="MessageHeaderStruct"/>
			<NOM:parameter name="targetID" dataType="uintBE"/>
			<NOM:parameter name="missionFlag" dataType="uintBE"/>
		</NOM:interaction>

		<!-- 0x0f MSSInterceptionResult : OC → MSS -->
		<NOM:interaction name="MSSInterceptionResult" id="0x0f" sharing="Publish"
			orderType="Receive" alignment="false" semantics="SAMS MSS interception result">
			<NOM:parameter name="Header" dataType="MessageHeaderStruct"/>
			<NOM:parameter name="targetID" dataType="uintBE"/>
			<NOM:parameter name="missionFlag" dataType="uintBE"/>
		</NOM:interaction>

		<!-- 0x10 Stop : OC → ATS/RSS/MLS/MSS -->
		<NOM:interaction name="Stop" id="0x10" sharing="Publish"
			orderType="Receive" alignment="false" semantics="SAMS stop simulation command">
			<NOM:parameter name="Header" dataType="MessageHeaderStruct"/>
			<NOM:parameter name="stopFlag" dataType="uintBE"/>
		</NOM:interaction>

		<!-- ============================================================ -->
		<!-- OC Subscribe : 각 CSC → OC 수신 메시지                        -->
		<!-- ============================================================ -->

		<!-- 0x02 ATSStatus : ATS → OC (주기) -->
		<NOM:interaction name="ATSStatus" id="0x02" sharing="Subscribe"
			orderType="Receive" alignment="false" semantics="SAMS ATS status">
			<NOM:parameter name="Header" dataType="MessageHeaderStruct"/>
			<NOM:parameter name="status" dataType="uintBE"/>
			<NOM:parameter name="targetInfo" dataType="ATSInformationStruct" size="4"/>
		</NOM:interaction>

		<!-- 0x03 RSSStatus : RSS → OC (주기) -->
		<NOM:interaction name="RSSStatus" id="0x03" sharing="Subscribe"
			orderType="Receive" alignment="false" semantics="SAMS RSS status">
			<NOM:parameter name="Header" dataType="MessageHeaderStruct"/>
			<NOM:parameter name="status" dataType="uintBE"/>
		</NOM:interaction>

		<!-- 0x04 MSSStatus : MSS → OC (주기) -->
		<NOM:interaction name="MSSStatus" id="0x04" sharing="Subscribe"
			orderType="Receive" alignment="false" semantics="SAMS MSS status">
			<NOM:parameter name="Header" dataType="MessageHeaderStruct"/>
			<NOM:parameter name="status" dataType="uintBE"/>
			<NOM:parameter name="missileInfo" dataType="MSSInformationStruct" size="4"/>
		</NOM:interaction>

		<!-- 0x05 MLSStatus : MLS → OC (주기) -->
		<NOM:interaction name="MLSStatus" id="0x05" sharing="Subscribe"
			orderType="Receive" alignment="false" semantics="SAMS MLS status">
			<NOM:parameter name="Header" dataType="MessageHeaderStruct"/>
			<NOM:parameter name="status" dataType="uintBE"/>
			<NOM:parameter name="launcherInfo" dataType="MLSInformationStruct"/>
		</NOM:interaction>

		<!-- 0x08 TargetDetection : RSS → OC (비주기) -->
		<NOM:interaction name="TargetDetection" id="0x08" sharing="Subscribe"
			orderType="Receive" alignment="false" semantics="SAMS target detection result">
			<NOM:parameter name="Header" dataType="MessageHeaderStruct"/>
			<NOM:parameter name="targetID" dataType="uintBE"/>
			<NOM:parameter name="targetDetectonSuccess" dataType="uintBE"/>
		</NOM:interaction>

		<!-- 0x0d TargetDestroyed : RSS → OC (비주기) -->
		<NOM:interaction name="TargetDestroyed" id="0x0d" sharing="Subscribe"
			orderType="Receive" alignment="false" semantics="SAMS target destroyed result">
			<NOM:parameter name="Header" dataType="MessageHeaderStruct"/>
			<NOM:parameter name="targetID" dataType="uintBE"/>
			<NOM:parameter name="missionFlag" dataType="uintBE"/>
		</NOM:interaction>

	</NOM:interactions>

	<NOM:dataTypes>
		<NOM:basicTypes/>
		<NOM:enumerationTypes/>
		<NOM:complexTypes/>
	</NOM:dataTypes>
	<NOM:notes/>

</NOM:Nex1ObjectModel>
