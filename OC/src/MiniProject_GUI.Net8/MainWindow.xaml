<Window x:Class="MiniProject_GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MiniProject_GUI"
        mc:Ignorable="d"
        Title="SAMS OC — Operation Control Station"
        Height="750" Width="1100"
        Background="#1A1D2E">

    <Window.Resources>
        <!-- 공통 색상 -->
        <SolidColorBrush x:Key="PanelBg"       Color="#252840"/>
        <SolidColorBrush x:Key="AccentBlue"    Color="#4A9EFF"/>
        <SolidColorBrush x:Key="AccentGreen"   Color="#3DDC84"/>
        <SolidColorBrush x:Key="AccentRed"     Color="#FF5252"/>
        <SolidColorBrush x:Key="AccentOrange"  Color="#FF9800"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#E8EAED"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#9AA0B4"/>
        <SolidColorBrush x:Key="BorderColor"   Color="#3A3F5C"/>

        <!-- 기본 버튼 스타일 -->
        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="Height"           Value="34"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="Foreground"       Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BlueButton"   BasedOn="{StaticResource BaseButton}" TargetType="Button">
            <Setter Property="Background"  Value="#2D5FA0"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
        </Style>
        <Style x:Key="GreenButton"  BasedOn="{StaticResource BaseButton}" TargetType="Button">
            <Setter Property="Background"  Value="#1D5C38"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentGreen}"/>
        </Style>
        <Style x:Key="RedButton"    BasedOn="{StaticResource BaseButton}" TargetType="Button">
            <Setter Property="Background"  Value="#7A1A1A"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentRed}"/>
        </Style>
        <Style x:Key="OrangeButton" BasedOn="{StaticResource BaseButton}" TargetType="Button">
            <Setter Property="Background"  Value="#6B3A00"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentOrange}"/>
        </Style>

        <!-- 패널 스타일 -->
        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Background"       Value="{StaticResource PanelBg}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="8"/>
            <Setter Property="Padding"          Value="12"/>
        </Style>

        <!-- 섹션 제목 -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="Foreground"   Value="{StaticResource AccentBlue}"/>
            <Setter Property="Margin"       Value="0,0,0,8"/>
        </Style>

        <!-- 라벨 -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- 입력 텍스트박스 -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background"    Value="#1A1D2E"/>
            <Setter Property="Foreground"    Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"   Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"       Value="6,4"/>
            <Setter Property="Height"        Value="28"/>
            <Setter Property="FontSize"      Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- 상태 DataGrid -->
        <Style x:Key="StatusGrid" TargetType="DataGrid">
            <Setter Property="Background"           Value="Transparent"/>
            <Setter Property="Foreground"           Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness"      Value="0"/>
            <Setter Property="GridLinesVisibility"  Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="RowBackground"        Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="#1F2238"/>
            <Setter Property="AutoGenerateColumns"  Value="False"/>
            <Setter Property="IsReadOnly"           Value="True"/>
            <Setter Property="FontSize"             Value="11"/>
            <Setter Property="HeadersVisibility"    Value="Column"/>
            <Setter Property="ColumnHeaderHeight"   Value="26"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>   <!-- 타이틀바 -->
            <RowDefinition Height="*"/>    <!-- 메인 콘텐츠 -->
            <RowDefinition Height="160"/>  <!-- 이벤트 로그 -->
        </Grid.RowDefinitions>

        <!-- ===== 타이틀 바 ===== -->
        <Border Grid.Row="0" Style="{StaticResource Panel}" Margin="0,0,0,8" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⬡" FontSize="20" Foreground="{StaticResource AccentBlue}" Margin="0,0,8,0"/>
                    <TextBlock Text="SAMS OC" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text=" — Operation Control Station"
                               FontSize="13" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Bottom" Margin="4,0,0,1"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="PlugInButton"  Content="Plug In"  Width="90" Style="{StaticResource BlueButton}"
                            Command="{Binding PlugInCommand}"  IsEnabled="{Binding IsPlugInEnabled}"/>
                    <Button x:Name="PlugOutButton" Content="Plug Out" Width="90" Margin="6,0,0,0" Style="{StaticResource RedButton}"
                            Command="{Binding PlugOutCommand}" IsEnabled="{Binding IsPlugOutEnabled}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== 메인 콘텐츠 ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*"/>  <!-- 시나리오 설정 -->
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="3*"/>    <!-- 상태 전시 -->
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="2.5*"/>  <!-- 교전 통제 -->
            </Grid.ColumnDefinitions>

            <!-- ─── 시나리오 설정 패널 ─── -->
            <Border Grid.Column="0" Style="{StaticResource Panel}">
                <StackPanel>
                    <TextBlock Text="▸ 시나리오 설정" Style="{StaticResource SectionTitle}"/>

                    <!-- 레이다 설정 -->
                    <TextBlock Text="레이다 (RSS)" FontSize="11" Foreground="{StaticResource AccentBlue}"
                               Margin="0,4,0,4" FontWeight="SemiBold"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="X" Style="{StaticResource FieldLabel}" Grid.Column="0"/>
                        <TextBox  x:Name="RssPosX"  Style="{StaticResource InputBox}" Grid.Column="1" Text="{Binding RssPosX}"/>
                        <TextBlock Text="Y" Style="{StaticResource FieldLabel}" Grid.Column="2" Margin="4,0,0,0"/>
                        <TextBox  x:Name="RssPosY"  Style="{StaticResource InputBox}" Grid.Column="3" Text="{Binding RssPosY}"/>
                        <TextBlock Text="Z" Style="{StaticResource FieldLabel}" Grid.Column="4" Margin="4,0,0,0"/>
                        <TextBox  x:Name="RssPosZ"  Style="{StaticResource InputBox}" Grid.Column="5" Text="{Binding RssPosZ}"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="46"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="반경(m)" Style="{StaticResource FieldLabel}"/>
                        <TextBox   x:Name="RssRadius" Grid.Column="1" Style="{StaticResource InputBox}" Text="{Binding RssRadius}"/>
                    </Grid>

                    <!-- 발사대 설정 -->
                    <TextBlock Text="발사대 (MLS)" FontSize="11" Foreground="{StaticResource AccentGreen}"
                               Margin="0,4,0,4" FontWeight="SemiBold"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="X" Style="{StaticResource FieldLabel}" Grid.Column="0"/>
                        <TextBox  x:Name="MlsPosX" Style="{StaticResource InputBox}" Grid.Column="1" Text="{Binding MlsPosX}"/>
                        <TextBlock Text="Y" Style="{StaticResource FieldLabel}" Grid.Column="2" Margin="4,0,0,0"/>
                        <TextBox  x:Name="MlsPosY" Style="{StaticResource InputBox}" Grid.Column="3" Text="{Binding MlsPosY}"/>
                        <TextBlock Text="Z" Style="{StaticResource FieldLabel}" Grid.Column="4" Margin="4,0,0,0"/>
                        <TextBox  x:Name="MlsPosZ" Style="{StaticResource InputBox}" Grid.Column="5" Text="{Binding MlsPosZ}"/>
                    </Grid>

                    <!-- 공중위협 설정 -->
                    <TextBlock Text="공중위협 (ATS)" FontSize="11" Foreground="{StaticResource AccentRed}"
                               Margin="0,4,0,4" FontWeight="SemiBold"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="표적 수" Style="{StaticResource FieldLabel}"/>
                        <TextBox   x:Name="TargetCount" Grid.Column="1" Style="{StaticResource InputBox}" Text="{Binding TargetCount}"/>
                    </Grid>
                    <!-- 표적 1 -->
                    <Border Background="#1A1D2E" BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="표적 1" FontSize="10" Foreground="{StaticResource AccentRed}" Margin="0,0,0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="X" Style="{StaticResource FieldLabel}" Grid.Column="0"/>
                                <TextBox  x:Name="T1StartX" Style="{StaticResource InputBox}" Grid.Column="1" Text="{Binding Target1StartX}"/>
                                <TextBlock Text="Y" Style="{StaticResource FieldLabel}" Grid.Column="2" Margin="4,0,0,0"/>
                                <TextBox  x:Name="T1StartY" Style="{StaticResource InputBox}" Grid.Column="3" Text="{Binding Target1StartY}"/>
                                <TextBlock Text="Z" Style="{StaticResource FieldLabel}" Grid.Column="4" Margin="4,0,0,0"/>
                                <TextBox  x:Name="T1StartZ" Style="{StaticResource InputBox}" Grid.Column="5" Text="{Binding Target1StartZ}"/>
                            </Grid>
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="속도(m/s)" Style="{StaticResource FieldLabel}" FontSize="10"/>
                                <TextBox  x:Name="T1Speed" Grid.Column="1" Style="{StaticResource InputBox}" Text="{Binding Target1Speed}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Separator Background="{StaticResource BorderColor}" Margin="0,8"/>

                    <!-- 시나리오 배포 버튼 -->
                    <Button x:Name="SendScenarioButton" Content="▶ 시나리오 배포 (Scenario)"
                            Style="{StaticResource BlueButton}" Margin="0,0,0,4"
                            Command="{Binding SendScenarioCommand}"
                            IsEnabled="{Binding IsPlugOutEnabled}"/>

                    <!-- 모의 제어 버튼 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="StartSimButton" Content="▶ START"
                                Style="{StaticResource GreenButton}" Grid.Column="0"
                                Command="{Binding StartSimulationCommand}"
                                IsEnabled="{Binding IsStartEnabled}"/>
                        <Button x:Name="StopSimButton"  Content="■ STOP"
                                Style="{StaticResource RedButton}" Grid.Column="2"
                                Command="{Binding StopSimulationCommand}"
                                IsEnabled="{Binding IsStopEnabled}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ─── 상태 전시 패널 ─── -->
            <Border Grid.Column="2" Style="{StaticResource Panel}">
                <StackPanel>
                    <TextBlock Text="▸ 시스템 상태 전시" Style="{StaticResource SectionTitle}"/>

                    <!-- CSC 연결 상태 표시줄 -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" CornerRadius="4" Padding="4,3" Margin="0,0,4,0"
                                Background="{Binding AtsStatusColor}">
                            <TextBlock Text="{Binding AtsStatusText}" FontSize="10" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="1" CornerRadius="4" Padding="4,3" Margin="0,0,4,0"
                                Background="{Binding RssStatusColor}">
                            <TextBlock Text="{Binding RssStatusText}" FontSize="10" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="2" CornerRadius="4" Padding="4,3" Margin="0,0,4,0"
                                Background="{Binding MlsStatusColor}">
                            <TextBlock Text="{Binding MlsStatusText}" FontSize="10" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="3" CornerRadius="4" Padding="4,3"
                                Background="{Binding MssStatusColor}">
                            <TextBlock Text="{Binding MssStatusText}" FontSize="10" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <!-- ATS 표적 목록 -->
                    <TextBlock Text="공중위협 (ATS)" FontSize="11" Foreground="{StaticResource AccentRed}"
                               Margin="0,0,0,4" FontWeight="SemiBold"/>
                    <DataGrid x:Name="AtsTable" Style="{StaticResource StatusGrid}"
                              ItemsSource="{Binding AtsTargetList}" Height="100" Margin="0,0,0,10">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"     Binding="{Binding TargetId}" Width="40"/>
                            <DataGridTextColumn Header="X(m)"   Binding="{Binding PosX, StringFormat=F0}" Width="*"/>
                            <DataGridTextColumn Header="Y(m)"   Binding="{Binding PosY, StringFormat=F0}" Width="*"/>
                            <DataGridTextColumn Header="Z(m)"   Binding="{Binding PosZ, StringFormat=F0}" Width="*"/>
                            <DataGridTextColumn Header="속도"   Binding="{Binding Speed}" Width="50"/>
                            <DataGridTextColumn Header="상태"   Binding="{Binding StatusText}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- MLS 발사대 상태 -->
                    <TextBlock Text="발사대 (MLS)" FontSize="11" Foreground="{StaticResource AccentGreen}"
                               Margin="0,0,0,4" FontWeight="SemiBold"/>
                    <Border Background="#1A1D2E" BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="유도탄1" FontSize="10" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding MlsMissile1}" FontSize="12" FontWeight="Bold"
                                           Foreground="{StaticResource AccentGreen}" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="유도탄2" FontSize="10" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding MlsMissile2}" FontSize="12" FontWeight="Bold"
                                           Foreground="{StaticResource AccentGreen}" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="유도탄3" FontSize="10" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding MlsMissile3}" FontSize="12" FontWeight="Bold"
                                           Foreground="{StaticResource AccentGreen}" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                <TextBlock Text="유도탄4" FontSize="10" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding MlsMissile4}" FontSize="12" FontWeight="Bold"
                                           Foreground="{StaticResource AccentGreen}" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                <TextBlock Text="재고" FontSize="10" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding MlsStock}" FontSize="12" FontWeight="Bold"
                                           Foreground="{StaticResource AccentOrange}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- MSS 유도탄 목록 -->
                    <TextBlock Text="유도탄 (MSS)" FontSize="11" Foreground="{StaticResource AccentOrange}"
                               Margin="0,0,0,4" FontWeight="SemiBold"/>
                    <DataGrid x:Name="MssTable" Style="{StaticResource StatusGrid}"
                              ItemsSource="{Binding MssMissileList}" Height="90">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"      Binding="{Binding MissileId}" Width="35"/>
                            <DataGridTextColumn Header="표적ID"  Binding="{Binding TargetId}" Width="45"/>
                            <DataGridTextColumn Header="X(m)"    Binding="{Binding PosX, StringFormat=F0}" Width="*"/>
                            <DataGridTextColumn Header="Y(m)"    Binding="{Binding PosY, StringFormat=F0}" Width="*"/>
                            <DataGridTextColumn Header="Z(m)"    Binding="{Binding PosZ, StringFormat=F0}" Width="*"/>
                            <DataGridTextColumn Header="상태"    Binding="{Binding StatusText}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- ─── 교전 통제 패널 ─── -->
            <Border Grid.Column="4" Style="{StaticResource Panel}">
                <StackPanel>
                    <TextBlock Text="▸ 교전 통제" Style="{StaticResource SectionTitle}"/>

                    <!-- 탐지 이벤트 -->
                    <TextBlock Text="탐지 이벤트 (TargetDetection)" FontSize="11"
                               Foreground="{StaticResource AccentOrange}" Margin="0,0,0,4" FontWeight="SemiBold"/>
                    <DataGrid x:Name="DetectionTable" Style="{StaticResource StatusGrid}"
                              ItemsSource="{Binding DetectionEventList}" Height="110" Margin="0,0,0,10">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="시각"    Binding="{Binding TimeStr}"  Width="55"/>
                            <DataGridTextColumn Header="표적ID"  Binding="{Binding TargetId}" Width="45"/>
                            <DataGridTextColumn Header="탐지"    Binding="{Binding Success}"  Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- 발사 명령 -->
                    <TextBlock Text="발사 명령 (LaunchCommand)" FontSize="11"
                               Foreground="{StaticResource AccentRed}" Margin="0,0,0,4" FontWeight="SemiBold"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="표적 ID" Style="{StaticResource FieldLabel}"/>
                        <TextBox   x:Name="LaunchTargetId" Grid.Column="1" Style="{StaticResource InputBox}"
                                   Text="{Binding LaunchTargetId}"/>
                        <Button    x:Name="LaunchButton" Grid.Column="3" Content="발사!"
                                   Style="{StaticResource RedButton}"
                                   Command="{Binding SendLaunchCommand}"
                                   IsEnabled="{Binding IsLaunchEnabled}"/>
                    </Grid>

                    <Separator Background="{StaticResource BorderColor}" Margin="0,6"/>

                    <!-- 요격 결과 -->
                    <TextBlock Text="요격 결과" FontSize="11" Foreground="{StaticResource AccentGreen}"
                               Margin="0,0,0,4" FontWeight="SemiBold"/>
                    <Border CornerRadius="6" Padding="10,8"
                            Background="{Binding InterceptionResultColor}" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="{Binding InterceptionResultText}"
                                       FontSize="15" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding InterceptionResultDetail}"
                                       FontSize="10" Foreground="White" Opacity="0.8"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- 요격 결과 이벤트 목록 -->
                    <DataGrid x:Name="ResultTable" Style="{StaticResource StatusGrid}"
                              ItemsSource="{Binding EngagementResultList}" Height="100">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="시각"   Binding="{Binding TimeStr}"  Width="55"/>
                            <DataGridTextColumn Header="결과"   Binding="{Binding Result}"   Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== 이벤트 로그 ===== -->
        <Border Grid.Row="2" Style="{StaticResource Panel}" Margin="0,8,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="▸ 이벤트 로그" Style="{StaticResource SectionTitle}" Margin="0"/>
                    <Button x:Name="ClearLogButton" Grid.Column="1" Content="Clear"
                            Width="60" Height="22" FontSize="10"
                            Style="{StaticResource BaseButton}"
                            Background="#2A2D40" BorderBrush="{StaticResource BorderColor}"
                            Command="{Binding ClearLogCommand}"/>
                </Grid>
                <ListBox x:Name="EventLog" Grid.Row="1"
                         ItemsSource="{Binding EventLogList}"
                         Background="Transparent" BorderThickness="0"
                         Foreground="{StaticResource TextSecondary}"
                         FontFamily="Consolas" FontSize="11"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </Border>
    </Grid>
</Window>
