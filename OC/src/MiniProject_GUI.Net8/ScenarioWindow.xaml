<Window x:Class="MiniProject_GUI.ScenarioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="시나리오 생성"
        Height="700" Width="920"
        MinHeight="620" MinWidth="820"
        WindowStartupLocation="CenterOwner"
        Background="#111111"
        FontFamily="Malgun Gothic">
    <Window.Resources>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAEAEA"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinWidth" Value="76"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1D1D1D"/>
            <Setter Property="BorderBrush" Value="#5A5A5A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ScenarioButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="Background" Value="#F2F2F2"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.42"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MiniButton" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="Background" Value="#F2F2F2"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.35"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="시나리오 생성"
                   Foreground="White" FontSize="26" FontWeight="Bold"
                   Margin="0,0,0,12"/>

        <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="1" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="레이다 / 탐지반경" Foreground="#00FF24" FontWeight="Bold" FontSize="16"/>
                <StackPanel Grid.Row="2" Orientation="Horizontal">
                    <TextBlock Text="X" Style="{StaticResource LabelText}"/>
                    <TextBox Text="{Binding RssPosX, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputBox}"/>
                    <TextBlock Text="Y" Style="{StaticResource LabelText}"/>
                    <TextBox Text="{Binding RssPosY, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputBox}"/>
                    <TextBlock Text="Z" Style="{StaticResource LabelText}"/>
                    <TextBox Text="{Binding RssPosZ, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputBox}" IsReadOnly="True" IsTabStop="False"/>
                    <TextBlock Text="R" Style="{StaticResource LabelText}" Margin="12,0,0,0"/>
                    <TextBox Text="{Binding RssRadius, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputBox}"/>
                </StackPanel>

                <TextBlock Grid.Column="2" Text="발사대" Foreground="#00FF24" FontWeight="Bold" FontSize="16"/>
                <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="X" Style="{StaticResource LabelText}"/>
                    <TextBox Text="{Binding MlsPosX, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputBox}"/>
                    <TextBlock Text="Y" Style="{StaticResource LabelText}"/>
                    <TextBox Text="{Binding MlsPosY, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputBox}"/>
                    <TextBlock Text="Z" Style="{StaticResource LabelText}"/>
                    <TextBox Text="{Binding MlsPosZ, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputBox}" IsReadOnly="True" IsTabStop="False"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="공중위협"
                       Foreground="#FFFF00"
                       FontSize="18"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <TextBlock Text="위협 추가/삭제"
                           Style="{StaticResource LabelText}"
                           Margin="0,0,8,0"/>
                <Button Content="+"
                        Style="{StaticResource MiniButton}"
                        Command="{Binding AddScenarioThreatCommand}"
                        IsEnabled="{Binding CanAddScenarioThreat}"/>
                <Button Content="-"
                        Style="{StaticResource MiniButton}"
                        Command="{Binding RemoveScenarioThreatCommand}"
                        IsEnabled="{Binding CanRemoveScenarioThreat}"/>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding ScenarioThreats}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1" Padding="12" Margin="0,0,0,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding Name}"
                                               Foreground="#FFFF00"
                                               FontSize="18"
                                               FontWeight="Bold"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="ID" Style="{StaticResource LabelText}" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding TargetId}"
                                                   Foreground="White"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="속도" Style="{StaticResource LabelText}"/>
                                    <TextBox Grid.Column="3" Text="{Binding Speed, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputBox}"/>
                                </Grid>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="경로점"
                                               Foreground="#00FF24"
                                               FontSize="15"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock Text="경로점 추가/삭제"
                                                   Style="{StaticResource LabelText}"
                                                   Margin="0,0,8,0"/>
                                        <Button Content="+"
                                                Style="{StaticResource MiniButton}"
                                                Command="{Binding DataContext.AddScenarioWaypointCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                IsEnabled="{Binding CanAddPoint}"/>
                                        <Button Content="-"
                                                Style="{StaticResource MiniButton}"
                                                Command="{Binding DataContext.RemoveScenarioWaypointCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                IsEnabled="{Binding CanRemovePoint}"/>
                                    </StackPanel>
                                </Grid>

                                <ItemsControl Grid.Row="4" ItemsSource="{Binding Points}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Label}" Style="{StaticResource LabelText}" FontWeight="Bold"/>
                                                <TextBlock Grid.Column="1" Text="X" Style="{StaticResource LabelText}"/>
                                                <TextBox Grid.Column="2" Text="{Binding X, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputBox}"/>
                                                <TextBlock Grid.Column="3" Text="Y" Style="{StaticResource LabelText}"/>
                                                <TextBox Grid.Column="4" Text="{Binding Y, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputBox}"/>
                                                <TextBlock Grid.Column="5" Text="Z" Style="{StaticResource LabelText}"/>
                                                <TextBox Grid.Column="6" Text="{Binding Z, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputBox}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="저장" Style="{StaticResource ScenarioButton}" Click="Save_Click"/>
            <Button Content="취소" Style="{StaticResource ScenarioButton}" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
