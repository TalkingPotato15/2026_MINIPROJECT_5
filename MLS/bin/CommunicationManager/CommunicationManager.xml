<NOM:Nex1ObjectModel xmlns:NOM="lignex1.sw.nframework.NOM" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="lignex1.sw.nframework.NOM NOM.xsd" version="0.1" name="CommunicationManager" date="2026-06-18" author="SAMS MLS">
  <NOM:objects/>
  <NOM:interactions>
    <NOM:interaction name="Scenario" id="0x01" sharing="PublishSubscribe" orderType="Receive" alignment="false" semantics="Receive Scenario(OC to ALL)">
      <NOM:parameter name="Header" dataType="MessageHeaderStruct"/>
      <NOM:parameter name="sceneInfo" dataType="TargetScenarioStruct" size="4"/>
      <NOM:parameter name="rssPos" dataType="PosStruct"/>
      <NOM:parameter name="rssRadius" dataType="uintBE"/>
      <NOM:parameter name="mlsPos" dataType="PosStruct"/>
    </NOM:interaction>
    <NOM:interaction name="MLSStatus" id="0x05" sharing="PublishSubscribe" orderType="Receive" alignment="false" semantics="Send MLS Status(MLS to OC)">
      <NOM:parameter name="Header" dataType="MessageHeaderStruct"/>
      <NOM:parameter name="status" dataType="uintBE"/>
      <NOM:parameter name="launcherInfo" dataType="MLSInformationStruct"/>
    </NOM:interaction>
    <NOM:interaction name="StartSimulation" id="0x06" sharing="PublishSubscribe" orderType="Receive" alignment="false" semantics="Receive start simulation command(OC to ALL)">
      <NOM:parameter name="Header" dataType="MessageHeaderStruct"/>
      <NOM:parameter name="startFlag" dataType="uintBE"/>
    </NOM:interaction>
    <NOM:interaction name="LaunchCommand" id="0x09" sharing="PublishSubscribe" orderType="Receive" alignment="false" semantics="Receive launch command(OC to MLS)">
      <NOM:parameter name="Header" dataType="MessageHeaderStruct"/>
      <NOM:parameter name="targetID" dataType="uintBE"/>
    </NOM:interaction>
    <NOM:interaction name="IgnitionCommand" id="0x0a" sharing="PublishSubscribe" orderType="Receive" alignment="false" semantics="Send Ignition command(MLS to MSS)">
      <NOM:parameter name="Header" dataType="MessageHeaderStruct"/>
      <NOM:parameter name="missileID" dataType="uintBE"/>
      <NOM:parameter name="targetID" dataType="uintBE"/>
      <NOM:parameter name="launchPos" dataType="PosStruct"/>
    </NOM:interaction>
    <NOM:interaction name="Stop" id="0x10" sharing="PublishSubscribe" orderType="Receive" alignment="false" semantics="Send stop simulation command(OC to ALL)">
      <NOM:parameter name="Header" dataType="MessageHeaderStruct"/>
      <NOM:parameter name="stopFlag" dataType="uintBE"/>
    </NOM:interaction>
    
    <NOM:interaction name="InnerMLSStatus" id="0x40" sharing="Subscribe" orderType="Receive" alignment="false" semantics="Receive Internal MLS status(LauncherControlManager to CommunicationManager)">
      <NOM:parameter name="status" dataType="uintBE"/>
      <NOM:parameter name="launcherInfo" dataType="MLSInformationStruct"/>
    </NOM:interaction>
    <NOM:interaction name="InnerScenario" id="0x41" sharing="Publish" orderType="Receive" alignment="false" semantics="Send Internal scenario(CommunicationManager to ScenarioManager)">
      <NOM:parameter name="mlsPos" dataType="PosStruct"/>
    </NOM:interaction>
    <NOM:interaction name="InnerStartSimulation" id="0x42" sharing="Publish" orderType="Receive" alignment="false" semantics="Send Internal start simulation command(CommunicationManager to ScenarioManager)">
    </NOM:interaction>
    <NOM:interaction name="InnerStop" id="0x43" sharing="Publish" orderType="Receive" alignment="false" semantics="Send Internal stop simulation command(CommunicationManager to ScenarioManager)">
    </NOM:interaction>
    <NOM:interaction name="InnerLaunchCommand" id="0x44" sharing="Publish" orderType="Receive" alignment="false" semantics="Send Internal launch command(CommunicationManager to LauncherControlManager)">
      <NOM:parameter name="targetID" dataType="uintBE"/>
    </NOM:interaction>
    <NOM:interaction name="InnerIgnitionCommand" id="0x48" sharing="Subscribe" orderType="Receive" alignment="false" semantics="Receive Internal launch command(LauncherControlManager to CommunicationManager)">
      <NOM:parameter name="missileID" dataType="uintBE"/>
      <NOM:parameter name="targetID" dataType="uintBE"/>
      <NOM:parameter name="launchPos" dataType="PosStruct"/>
    </NOM:interaction>
  </NOM:interactions>
  <NOM:dataTypes>
    <NOM:basicTypes/>
    <NOM:enumerationTypes/>
    <NOM:complexTypes/>
  </NOM:dataTypes>
  <NOM:notes/>
</NOM:Nex1ObjectModel>
