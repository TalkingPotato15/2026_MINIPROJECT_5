<?xml version="1.0" encoding="UTF-8"?>
<NOM:Nex1ObjectModel xmlns:NOM="lignex1.sw.nframework.NOM"
   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
   xsi:schemaLocation="lignex1.sw.nframework.NOM NOM.xsd"
   version="0.1" name="CommunicationManager" date="2026-06-18" author="SAMS OC">

	<NOM:objects/>

	<NOM:interactions>

    <NOM:interaction name="Scenario" id="0x01" sharing="PublishSubscribe" orderType="Receive" alignment="false" semantics="SAMS scenario distribution">
      <NOM:parameter name="Header" dataType="MessageHeaderStruct"/>
      <NOM:parameter name="sceneInfo" dataType="TargetScenarioStruct" size="4"/>
      <NOM:parameter name="rssPos" dataType="PosStruct"/>
      <NOM:parameter name="rssRadius" dataType="uintBE"/>
      <NOM:parameter name="mlsPos" dataType="PosStruct"/>
    </NOM:interaction>
    <NOM:interaction name="MSSStatus" id="0x04" sharing="PublishSubscribe" orderType="Receive" alignment="false" semantics="SAMS MSS status">
      <NOM:parameter name="Header" dataType="MessageHeaderStruct"/>
      <NOM:parameter name="status" dataType="uintBE"/>
      <NOM:parameter name="missileInfo" dataType="MSSInformationStruct" size="4"/>
    </NOM:interaction>
    
    <NOM:interaction name="StartSimulation" id="0x06" sharing="PublishSubscribe" orderType="Receive" alignment="false" semantics="SAMS start simulation command">
      <NOM:parameter name="Header" dataType="MessageHeaderStruct"/>
      <NOM:parameter name="startFlag" dataType="uintBE"/>
    </NOM:interaction>
    <NOM:interaction name="Stop" id="0x10" sharing="PublishSubscribe" orderType="Receive" alignment="false" semantics="SAMS stop simulation command">
      <NOM:parameter name="Header" dataType="MessageHeaderStruct"/>
      <NOM:parameter name="stopFlag" dataType="uintBE"/>
    </NOM:interaction>

    <NOM:interaction name="InnerScenario" id="0x41" sharing="Subscribe" orderType="Receive" alignment="false" semantics="Internal scenario distribution">
      <NOM:parameter name="mlsPos" dataType="PosStruct"/>
    </NOM:interaction>
    <NOM:interaction name="InnerStartSimulation" id="0x42" sharing="Subscribe" orderType="Receive" alignment="false" semantics="Internal start simulation command">
    </NOM:interaction>
    <NOM:interaction name="InnerStop" id="0x43" sharing="Subscribe" orderType="Receive" alignment="false" semantics="Internal stop simulation command">
    </NOM:interaction>
    <NOM:interaction name="InnerSettingScenario" id="0x45" sharing="Publish" orderType="Receive" alignment="false" semantics="Internal scenario distribution">
      <NOM:parameter name="mlsPos" dataType="PosStruct"/>
    </NOM:interaction>
    <NOM:interaction name="InnerStartMLS" id="0x46" sharing="Publish" orderType="Receive" alignment="false" semantics="Internal start simulation command">
    </NOM:interaction>
    <NOM:interaction name="InnerStopMLS" id="0x47" sharing="Publish" orderType="Receive" alignment="false" semantics="Internal stop simulation command">
    </NOM:interaction>

	</NOM:interactions>

	<NOM:dataTypes>
		<NOM:basicTypes/>
		<NOM:enumerationTypes/>
		<NOM:complexTypes/>
	</NOM:dataTypes>
	<NOM:notes/>

</NOM:Nex1ObjectModel>

